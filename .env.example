# AWS Bedrock config.
# This repo now uses Bedrock for all live LLM calls.
# If AWS credentials are already exported in your shell or profile, you usually only need a region.
# You can also place temporary session credentials here if that is how you are testing Bedrock.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-west-2
BEDROCK_REGION=us-west-2
BEDROCK_REASONING_MODEL=deepseek.v3.2
BEDROCK_FAST_MODEL=deepseek.v3.2
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# Legacy non-Bedrock settings are intentionally commented out.
# GEMINI_API_KEY=
# GEMINI_API_BASE_URL=
# GEMINI_REASONING_MODEL=
# GEMINI_FAST_MODEL=

DATABASE_URL=sqlite:///./grab_collections.db

# Commitment breach threshold before freezing autonomous restructuring
COMMITMENT_FREEZE_THRESHOLD=2

# Set true only when you want hardcoded responses and no external LLM call.
USE_MOCK_LLM=false

# Gemini API for local testing.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_REASONING_MODEL=gemini-1.5-flash
GEMINI_FAST_MODEL=gemini-1.5-flash

# Generic OpenAI-compatible config kept as an alternate for later.
# LLM_API_KEY=your_llm_api_key_here
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_REASONING_MODEL=gpt-4o-mini
# LLM_FAST_MODEL=gpt-4o-mini

# AWS Bedrock config for later.
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_here
# AWS_DEFAULT_REGION=ap-southeast-1
# BEDROCK_REGION=ap-southeast-1
# BEDROCK_REASONING_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_FAST_MODEL=anthropic.claude-3-haiku-20240307-v1:0
# BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

DATABASE_URL=sqlite:///./grab_collections.db

# Commitment breach threshold before freezing autonomous restructuring
COMMITMENT_FREEZE_THRESHOLD=2

# Set true only when you want hardcoded responses and no external LLM call.
USE_MOCK_LLM=false
